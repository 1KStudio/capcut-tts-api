# Server Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=false

# Cloudflare R2 Storage (S3-compatible)
# Copy from german-learning-be .env
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=german-learning
R2_PUBLIC_URL=https://storage.colenboro.xyz

# CapCut API
CAPCUT_API_BASE=https://editor-api-sg.capcutapi.com

# CapCut Device Profile (optional - will generate random if empty)
CAPCUT_DEVICE_ID=
CAPCUT_IID=
CAPCUT_TDID=

# Default Voices
DEFAULT_VOICE_VI=BV074_streaming
DEFAULT_RESOURCE_ID_VI=7102355709945188865
DEFAULT_VOICE_DE=DiT_de_male_koubo
DEFAULT_RESOURCE_ID_DE=7584344912276114704

# Polling Configuration
POLL_MAX_ATTEMPTS=30
POLL_INTERVAL=0.5
